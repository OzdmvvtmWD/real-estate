<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <record id="estate_type_action" model="ir.actions.act_window">
        <field name="name">Property Type</field>
        <field name="res_model">estate.property.type</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="estate_type_tree_view" model="ir.ui.view">
        <field name="name">estate.type.tree</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <tree string="Property Types">
                <field name="sequence" widget="handle"/>
                <field name="name" string="Property Type"/>
            </tree>
        </field>
    </record>
    <record id="estate_form_type_view" model="ir.ui.view">
        <field name="name">estate.type.form</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <form string="My New Type">
                <sheet>
                    <header>
                        <button special="save" string="Save"/>
                    </header>
                    <div style="text-align: right; border: 2px grey">
                        <button
                                icon="fa-money"
                                style="display:inline-block; border: 2px grey"
                                type="action"
                                name="%(estate_offer_action)d">
                            <field name="offer_count" widget="statinfo" string=""/>
                            <p>Offer</p>
                        </button>
                    </div>
                    <div class="oe_title">
                        <h1>
                            <field name="name" nolable="True" placeholder="Property Type"/>
                        </h1>
                    </div>
                    <notebook>
                        <page string="Properties">
                            <field name="property_ids">
                                <tree>
                                    <field name="name" string="Title"/>
                                    <field name="expected_price"/>
                                    <field name="state" string="Status"/>
                                </tree>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>
    <record id="estate_search_type_view" model="ir.ui.view">
        <field name="name">estate.search</field>
        <field name="model">estate.property.type</field>
        <field name="arch" type="xml">
            <search string="Properties Type">
                <field name="name" string="Property Type"/>
            </search>
        </field>
    </record>
</odoo>