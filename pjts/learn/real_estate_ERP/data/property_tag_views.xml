<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="estate_actions_tags" model="ir.actions.act_window">
        <field name="name">Property Tags</field>
        <field name="res_model">estate.property.tag</field>
        <field name="view_mode">tree,form</field>
    </record>

    <record id="estate_tag_tree_view" model="ir.ui.view">
        <field name="name">estate.tag.tree</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <tree string="Property Tags" editable="bottom">
                <field name="name" string="Property Tag"/>
            </tree>
        </field>
    </record>
    <record id="estate_form_tag_view" model="ir.ui.view">
        <field name="name">estate.tag.form</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <form string="My New Tag">
                <sheet>
                    <header>
                        <button special="save" string="Save"/>

                    </header>
                    <div class="oe_title">
                        <h1>
                            <field name="name" nolable="True" placeholder="Property Tag"/>
                        </h1>
                    </div>
                </sheet>
            </form>
        </field>
    </record>
    <record id="estate_search_tag_view" model="ir.ui.view">
        <field name="name">estate.search</field>
        <field name="model">estate.property.tag</field>
        <field name="arch" type="xml">
            <search string="Properties Type">
                <field name="name" string="Property Type"/>
            </search>
        </field>
    </record>
</odoo>