<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="estate_offer_action" model="ir.actions.act_window">
        <field name="name">Property Offer</field>
        <field name="res_model">estate.property.offer</field>
        <field name="view_mode">tree,form</field>
        <field name="domain">[('property_type_id', '=', active_id)]</field>
    </record>
    <record id="offer_tree_view" model="ir.ui.view">
        <field name="name">estate.offer.tree</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <tree string="Property Offers" editable="bottom"
                  decoration-success="status=='accepted'"
                  decoration-danger="status=='refuse'">
                <field name="price"/>
                <field name="partner_id" string="Partner"/>
                <field name="validity" string="Validity days"/>
                <field name="date_deadline" string="Deadline"/>
                <button name="accepted_offer" type="object" icon="fa-check"
                        invisible="status in ('refuse','accepted')"
                />
                <button name="refuse_offer" type="object" icon="fa-times"
                        invisible="status in ('refuse','accepted')"
                />
                <field name="status" string="Status" invisible="1"/>
            </tree>
        </field>
    </record>
    <record id="form_offer_view" model="ir.ui.view">
        <field name="name">estate.offer.form</field>
        <field name="model">estate.property.offer</field>
        <field name="arch" type="xml">
            <form string="Offers">
                <sheet>
                    <group>
                        <field name="price"/>
                        <field name="status" string="Status"/>
                        <field name="validity" string="Validity days"/>
                        <field name="date_deadline" string="Deadline"/>
                        <field name="partner_id" string="Partner"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>
</odoo>