<?xml version="1.0" encoding="UTF-8" ?>
<odoo>
    <record id="crm_lead_wizard_form_view" model="ir.ui.view">
        <field name="name">crm.lead_wizard.form.view</field>
        <field name="model">client.risk.level</field>
        <field name="arch" type="xml">
            <form string="Client Risk Level">
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" placeholder="Set level risk"/>
                        </h1>
                    </div>
                    <footer>
                        <button name="set_client_risk_level" string="OK"
                                type="object" class="oe_highlight"/>
                        <button string="Cancel" class="btn-secondary"
                                special="cancel"/>
                    </footer>
                </sheet>
            </form>

        </field>
    </record>

</odoo>